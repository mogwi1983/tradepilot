# Secrets — never commit
.env.local
.env
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Pipeline runtime (logs stay local; structure tracked via .gitkeep)
runs/*/
!runs/.gitkeep
!runs/README.md

# Data outputs (source CSVs in data/source/ are committed; phase outputs are not)
data/output/*.csv
data/output/*.md
!data/output/README.md
!data/output/.gitkeep
data/search_cache.sqlite
data/dashboard_job.json
data/pipeline_state.json

# Temp / atomic write artifacts
*.tmp
*.swp
