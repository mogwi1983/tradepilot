# Copy to .env.local and fill in values. Never commit .env.local.

# LLM provider for pipeline phases (minimax | deepseek)
LLM_PROVIDER=minimax

# MiniMax M2.7 (default) — OpenAI-compatible
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# DeepSeek (comparison / fallback)
DEEPSEEK_API_KEY=

# Address verification — use test key for development
LOB_API_KEY=
LOB_SECRET_API_KEY_TEST=
LOB_SECRET_API_KEY_LIVE=

# Browser automation
BROWSER_USE_HEADLESS=true
